# Copy to frontend/.env.local and adjust. NEXT_PUBLIC_* is validated by lib/env.ts
# (zod) at boot. NEVER commit the real .env.local (see .gitignore).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# --- Copy generation (server-side only — the key lives HERE, not on FastAPI) ---
# Read by the Next.js route app/api/quips/route.ts. Optional: without a key the
# "Generate ideas" button fails loud (503) and you paste copy manually.
# CRITICAL: do NOT prefix these with NEXT_PUBLIC_ — that would ship the key to the
# browser. They are server-only and never reach client code.
ANTHROPIC_API_KEY=
# Cheapest model that clears the humor bar (we generate a batch and you pick).
# Set to a Sonnet id (e.g. claude-sonnet-5) for wittier, pricier output.
QUIP_MODEL=claude-haiku-4-5
QUIP_COUNT=6
QUIP_MAX_CHARS=80
