# Copy to frontend/.env.local and adjust. NEXT_PUBLIC_* is validated by lib/env.ts
# (zod) at boot. NEVER commit the real .env.local (see .gitignore).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# --- Copy generation (server-side only — the key lives HERE, not on FastAPI) ---
# Read by the Next.js route app/api/quips/route.ts. Optional: without a key the
# "Generate ideas" button fails loud (503) and you paste copy manually.
# CRITICAL: do NOT prefix these with NEXT_PUBLIC_ — that would ship the key to the
# browser. They are server-only and never reach client code.
ANTHROPIC_API_KEY=
# Copy generation is two-stage (generate → judge). QUIP_MODEL writes the
# candidates (Sonnet by default — comedy is the product); QUIP_JUDGE_MODEL scores
# them down to the best (Haiku — judging is cheaper than writing).
QUIP_MODEL=claude-sonnet-5
QUIP_JUDGE_MODEL=claude-haiku-4-5
QUIP_COUNT=6
QUIP_MAX_CHARS=80
# Where the "hall of fame" (shipped design copy → few-shot house voice) is stored.
# Relative to the Next.js server CWD (frontend/), so this default lands at
# repo-root/data/copy/hall-of-fame.json. See docs/TRENDS-DISCOVERY-SPEC.md Part B.
HALL_OF_FAME_PATH=../data/copy/hall-of-fame.json
