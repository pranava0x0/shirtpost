# Copy to backend/.env and fill in. NEVER commit the real .env (see .gitignore).
# List-typed vars are JSON-encoded.

# --- Database ---
DATABASE_URL=sqlite:///./shirtpost.db

# --- Security / network ---
ALLOWED_HOSTS=["localhost","127.0.0.1"]
ADMIN_CORS_ORIGINS=["http://localhost:3000"]

# --- Radar ---
RADAR_ENABLED=true
RADAR_POLL_INTERVAL_SECONDS=900
# Sources: "simulated" (no network), "wikipedia" (open pageviews API, ToS-clean),
# "google_trends" (unofficial RSS — official alpha API is the production path).
# Reddit was dropped (its free API forbids commercial use).
RADAR_SOURCES=["simulated"]
# Family-friendly gate: drop trends whose term matches a blocklisted word before
# they reach the queue. FAMILY_BLOCKLIST is JSON; leave the default or override.
FAMILY_SAFE_FILTER_ENABLED=true

# --- Copy generation (funny one-liner shirt slogans from trends) ---
# Optional. With a key, the Studio's "Generate ideas" button asks Claude for
# banger one-liners riffed on a trend; without it that endpoint fails loud (503)
# and you paste copy manually. Key is read here only, never logged.
ANTHROPIC_API_KEY=
# Cheapest model that clears the humor bar (we generate a batch and you pick).
# Set to a Sonnet id (e.g. claude-sonnet-5) for wittier, pricier output.
QUIP_MODEL=claude-haiku-4-5
QUIP_COUNT=6
QUIP_MAX_CHARS=80

# --- Printful ---
PRINTFUL_API_KEY=
PRINTFUL_STORE_ID=
PRINTFUL_DEFAULT_PRODUCT_ID=71
PRINTFUL_DEFAULT_VARIANT_ID=4012
# Garment color the print sits on. Drives the ink color for contrast (light
# garment -> dark ink, dark garment -> white). Set this whenever you change the
# variant, or the art can print invisibly (white-on-white). Name or #RRGGBB hex.
PRINTFUL_GARMENT_COLOR=black

# --- Print-file storage (Printful fetches the PNG by public URL) ---
# "local": serve from this backend at PUBLIC_BASE_URL/artifacts/<id>.png. Only
#   works when PUBLIC_BASE_URL is publicly reachable (deployed); fails loud on
#   localhost. "github_pages": push the PNG to a public artifacts repo + poll
#   until live ($0, no card) — set the three GITHUB_* vars.
PRINT_FILE_STORAGE=local
GITHUB_ARTIFACTS_REPO=
GITHUB_TOKEN=
GITHUB_PAGES_BASE_URL=

# --- Factory ---
# Dry-run: complete the pipeline without Printful/X (dev/demo). Drops reach
# "published" with clearly-marked simulated outputs. Default false so a real
# misconfiguration still fails loud.
FACTORY_DRY_RUN=false
# Public base URL of this backend (used to build reachable artifact/mockup URLs).
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Public storefront base URL. When set, the X broadcast links a real shop
# page; unset (Phase 1) the post is a teaser, not a buyable "live" claim.
STORE_BASE_URL=

# --- X.com broadcast ---
# X has no free API tier since 2026-02 (~$0.20/post with a URL). Default "intent":
# the Factory generates a prefilled x.com/intent/post URL and the operator clicks
# Post ($0, no keys). "api" auto-posts via the OAuth creds below (metered).
X_BROADCAST_MODE=intent
# Fail-loud monthly spend cap for api mode (USD). Empty = no cap.
X_MONTHLY_BUDGET_USD=
# Only needed when X_BROADCAST_MODE=api (OAuth 1.0a user context).
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
